{
  "name": "poc-web-server",
  "version": "1.0.0",
  "description": "Fastify REST API for the PoC web dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test:integration": "npm run build && node test/integration_tests.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.12.0",
    "pino-pretty": "^11.2.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
