{
  "name": "poc-web-server",
  "version": "1.0.0",
  "description": "Fastify REST API for the PoC web dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest --passWithNoTests",
    "test:integration": "npm run build && node test/integration_tests.js"
  },
  "dependencies": {
    "@data-engineering-poc/read-only-sql": "file:../../packages/read-only-sql",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.12.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
