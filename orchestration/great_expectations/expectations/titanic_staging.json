{
  "expectation_suite_name": "titanic_staging",
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.21"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 800, "max_value": 1000 },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "passenger_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "passenger_id" },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "survived", "value_set": [0, 1] },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": { "column": "pclass", "value_set": [1, 2, 3] },
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "fare", "min_value": 0, "strict_min": false },
      "meta": {}
    }
    ,
    {
      "expectation_type": "expect_column_mean_to_be_between",
      "kwargs": { "column": "survived", "min_value": 0.35, "max_value": 0.45 },
      "meta": { "description": "Historical survival rate (SUM(survived)/COUNT(*)) expected between 35% and 45%." }
    },
    {
      "expectation_type": "expect_column_proportion_of_values_to_be_between",
      "kwargs": { "column": "pclass", "value": 1, "min_value": 0.25, "max_value": 0.5 },
      "meta": { "description": "Approximate proportion for pclass=1 (tune as needed)." }
    },
    {
      "expectation_type": "expect_column_proportion_of_values_to_be_between",
      "kwargs": { "column": "pclass", "value": 2, "min_value": 0.25, "max_value": 0.5 },
      "meta": { "description": "Approximate proportion for pclass=2 (tune as needed)." }
    },
    {
      "expectation_type": "expect_column_proportion_of_values_to_be_between",
      "kwargs": { "column": "pclass", "value": 3, "min_value": 0.25, "max_value": 0.5 },
      "meta": { "description": "Approximate proportion for pclass=3 (tune as needed)." }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "loaded_at" },
      "meta": { "description": "Freshness indicator: loaded_at must be present; orchestration uses this field to assert recent loads.", "freshness": { "loaded_at_field": "loaded_at", "warn_after_hours": 24, "error_after_hours": 48 } }
    }
  ]
}
